// ─── Models ─────────────────────────────────────────────────────────────────

model Organization {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  tier             OrganizationTier @default(FREE)
  stripeCustomerId String?          @map("stripe_customer_id")
  settings         Json             @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  memberships                         OrganizationMembership[]
  buildings                           Building[]
  buildingPropertyUses                BuildingPropertyUse[]
  complianceRuns                      ComplianceRun[]
  sourceArtifacts                     SourceArtifact[]
  evidenceArtifacts                   EvidenceArtifact[]
  benchmarkSubmissions                BenchmarkSubmission[]
  filingRecords                       FilingRecord[]
  filingRecordEvents                  FilingRecordEvent[]
  filingPackets                       FilingPacket[]
  benchmarkRequestItems               BenchmarkRequestItem[]
  benchmarkPackets                    BenchmarkPacket[]
  verificationItemResults             VerificationItemResult[]
  dataIssues                          DataIssue[]
  bepsRequestItems                    BepsRequestItem[]
  bepsMetricInputs                    BepsMetricInput[]
  bepsPrescriptiveItems               BepsPrescriptiveItem[]
  bepsAlternativeComplianceAgreements BepsAlternativeComplianceAgreement[]
  portfolioManagerManagement          PortfolioManagerManagement?
  portfolioManagerImportState         PortfolioManagerImportState?
  portfolioManagerRemoteProperties    PortfolioManagerRemoteProperty[]
  portfolioManagerRemoteMeters        PortfolioManagerRemoteMeter[]
  portfolioManagerProvisioningStates  PortfolioManagerProvisioningState[]
  portfolioManagerSetupStates         PortfolioManagerSetupState[]
  portfolioManagerPropertyUseInputs   PortfolioManagerPropertyUseInput[]
  portfolioManagerMeterLinkStates     PortfolioManagerMeterLinkState[]
  portfolioManagerUsageStates         PortfolioManagerUsageState[]
  portfolioManagerSyncStates          PortfolioManagerSyncState[]
  operationalAnomalies                OperationalAnomaly[]
  retrofitCandidates                  RetrofitCandidate[]
  financingCases                      FinancingCase[]
  financingCaseCandidates             FinancingCaseCandidate[]
  financingPackets                    FinancingPacket[]
  penaltyRuns                         PenaltyRun[]
  submissionWorkflows                 SubmissionWorkflow[]
  submissionWorkflowEvents            SubmissionWorkflowEvent[]
  auditLogs                           AuditLog[]
  jobs                                Job[]
  buildingSourceReconciliations       BuildingSourceReconciliation[]
  meterSourceReconciliations          MeterSourceReconciliation[]
  reportArtifacts                     ReportArtifact[]
  utilityBillUploads                  UtilityBillUpload[]
  utilityBillCandidates               UtilityBillCandidate[]
  approvalRequests                    ApprovalRequest[]

  @@map("organizations")
}

model User {
  id              String    @id @default(cuid())
  authUserId      String    @unique @map("auth_user_id")
  email           String    @unique
  name            String
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships OrganizationMembership[]

  @@map("users")
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           UserRole @default(VIEWER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_memberships")
}

model Building {
  id                                String                @id @default(cuid())
  organizationId                    String                @map("organization_id")
  name                              String
  address                           String
  latitude                          Float
  longitude                         Float
  grossSquareFeet                   Int                   @map("gross_square_feet")
  propertyType                      PropertyType          @map("property_type")
  ownershipType                     BuildingOwnershipType @default(PRIVATE) @map("ownership_type")
  yearBuilt                         Int?                  @map("year_built")
  isEnergyStarScoreEligible         Boolean?              @map("is_energy_star_score_eligible")
  espmPropertyId                    BigInt?               @map("espm_property_id")
  espmShareStatus                   EspmShareStatus       @default(UNLINKED) @map("espm_share_status")
  greenButtonStatus                 GreenButtonStatus     @default(NONE) @map("green_button_status")
  dataIngestionMethod               DataIngestionMethod   @default(CSV_UPLOAD) @map("data_ingestion_method")
  bepsTargetScore                   Float                 @map("beps_target_score")
  maxPenaltyExposure                Float                 @default(0) @map("max_penalty_exposure")
  complianceCycle                   ComplianceCycle       @default(CYCLE_1) @map("compliance_cycle")
  selectedPathway                   SelectedPathway       @default(NONE) @map("selected_pathway")
  doeeBuildingId                    String?               @map("doee_building_id")
  baselineYear                      Int?                  @map("baseline_year")
  targetEui                         Float?                @map("target_eui")
  ward                              Int?
  hasFinancialDistress              Boolean               @default(false) @map("has_financial_distress")
  occupancyRate                     Float?                @map("occupancy_rate")
  irrigatedAreaSquareFeet           Int?                  @map("irrigated_area_square_feet")
  numberOfBuildings                 Int                   @default(1) @map("number_of_buildings")
  plannedConstructionCompletionYear Int?                  @map("planned_construction_completion_year")
  createdAt                         DateTime              @default(now()) @map("created_at")
  updatedAt                         DateTime              @updatedAt @map("updated_at")

  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  energyReadings                      EnergyReading[]
  complianceSnapshots                 ComplianceSnapshot[]
  pipelineRuns                        PipelineRun[]
  greenButtonConnection               GreenButtonConnection?
  meters                              Meter[]
  driftAlerts                         DriftAlert[]
  complianceRuns                      ComplianceRun[]
  sourceArtifacts                     SourceArtifact[]
  evidenceArtifacts                   EvidenceArtifact[]
  benchmarkSubmissions                BenchmarkSubmission[]
  filingRecords                       FilingRecord[]
  filingRecordEvents                  FilingRecordEvent[]
  filingPackets                       FilingPacket[]
  benchmarkRequestItems               BenchmarkRequestItem[]
  benchmarkPackets                    BenchmarkPacket[]
  verificationItemResults             VerificationItemResult[]
  dataIssues                          DataIssue[]
  bepsRequestItems                    BepsRequestItem[]
  bepsMetricInputs                    BepsMetricInput[]
  bepsPrescriptiveItems               BepsPrescriptiveItem[]
  bepsAlternativeComplianceAgreements BepsAlternativeComplianceAgreement[]
  propertyUses                        BuildingPropertyUse[]
  portfolioManagerProvisioningState   PortfolioManagerProvisioningState?
  portfolioManagerSetupState          PortfolioManagerSetupState?
  portfolioManagerPropertyUseInputs   PortfolioManagerPropertyUseInput[]
  portfolioManagerMeterLinkStates     PortfolioManagerMeterLinkState[]
  portfolioManagerUsageState          PortfolioManagerUsageState?
  portfolioManagerSyncStates          PortfolioManagerSyncState[]
  portfolioManagerRemoteProperties    PortfolioManagerRemoteProperty[]
  operationalAnomalies                OperationalAnomaly[]
  retrofitCandidates                  RetrofitCandidate[]
  financingCases                      FinancingCase[]
  financingCaseCandidates             FinancingCaseCandidate[]
  financingPackets                    FinancingPacket[]
  penaltyRuns                         PenaltyRun[]
  submissionWorkflows                 SubmissionWorkflow[]
  submissionWorkflowEvents            SubmissionWorkflowEvent[]
  sourceReconciliation                BuildingSourceReconciliation?
  meterReconciliations                MeterSourceReconciliation[]
  auditLogs                           AuditLog[]
  approvalRequests                    ApprovalRequest[]
  jobs                                Job[]
  reportArtifacts                     ReportArtifact[]
  utilityBillUploads                  UtilityBillUpload[]
  utilityBillCandidates               UtilityBillCandidate[]

  @@unique([id, organizationId])
  @@index([organizationId])
  @@map("buildings")
}

model BuildingPropertyUse {
  id                String                  @id @default(cuid())
  organizationId    String                  @map("organization_id")
  buildingId        String                  @map("building_id")
  sortOrder         Int                     @default(0) @map("sort_order")
  useKey            BuildingPropertyUseType @map("use_key")
  displayName       String                  @map("display_name")
  grossSquareFeet   Int                     @map("gross_square_feet")
  detailsJson       Json                    @default("{}") @map("details_json")
  espmPropertyUseId BigInt?                 @map("espm_property_use_id")
  espmUseDetailsId  BigInt?                 @map("espm_use_details_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  building     Building     @relation(fields: [buildingId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@index([organizationId, buildingId, sortOrder])
  @@map("building_property_uses")
}

model Meter {
  id                        String     @id @default(cuid())
  buildingId                String     @map("building_id")
  organizationId            String     @map("organization_id")
  espmMeterId               BigInt?    @map("espm_meter_id")
  espmMeterTypeRaw          String?    @map("espm_meter_type_raw")
  espmMeterUnitOfMeasureRaw String?    @map("espm_meter_unit_of_measure_raw")
  meterType                 MeterType  @map("meter_type")
  name                      String
  unit                      EnergyUnit
  isActive                  Boolean    @default(true) @map("is_active")
  createdAt                 DateTime   @default(now()) @map("created_at")

  building                       Building                        @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  energyReadings                 EnergyReading[]
  operationalAnomalies           OperationalAnomaly[]
  portfolioManagerMeterLinkState PortfolioManagerMeterLinkState?
  reconciliation                 MeterSourceReconciliation?

  @@index([buildingId])
  @@index([organizationId])
  @@map("meters")
}

model EnergyReading {
  id              String       @id @default(cuid())
  buildingId      String       @map("building_id")
  organizationId  String       @map("organization_id")
  source          EnergySource
  meterType       MeterType    @map("meter_type")
  periodStart     DateTime     @map("period_start")
  periodEnd       DateTime     @map("period_end")
  consumption     Float
  unit            EnergyUnit
  consumptionKbtu Float        @map("consumption_kbtu")
  cost            Float?
  isVerified      Boolean      @default(false) @map("is_verified")
  uploadBatchId   String?      @map("upload_batch_id")
  rawPayload      Json?        @map("raw_payload")
  ingestedAt      DateTime     @default(now()) @map("ingested_at")
  meterId         String?      @map("meter_id")
  archivedAt      DateTime?    @map("archived_at")
  archivedReason  String?      @map("archived_reason")
  archivedByOperationalJobId String? @map("archived_by_operational_job_id")

  building Building @relation(fields: [buildingId, organizationId], references: [id, organizationId], onDelete: Cascade)
  meter    Meter?   @relation(fields: [meterId], references: [id])

  @@index([buildingId, periodStart(sort: Desc)])
  @@index([buildingId, source, ingestedAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@index([organizationId, buildingId, meterId, periodEnd(sort: Desc), ingestedAt(sort: Desc)])
  @@index([organizationId, buildingId, meterId, archivedAt, periodEnd(sort: Desc), ingestedAt(sort: Desc)])
  @@map("energy_readings")
}

model UtilityBillUpload {
  id                 String                       @id @default(cuid())
  organizationId     String                       @map("organization_id")
  buildingId         String                       @map("building_id")
  sourceArtifactId   String?                      @unique @map("source_artifact_id")
  status             UtilityBillUploadStatus      @default(QUEUED)
  extractionMethod   UtilityBillExtractionMethod? @map("extraction_method")
  originalFileName   String                       @map("original_file_name")
  mimeType           String                       @map("mime_type")
  fileSizeBytes      Int                          @map("file_size_bytes")
  storageBucket      String                       @map("storage_bucket")
  storagePath        String                       @map("storage_path")
  rawText            String?                      @map("raw_text") @db.Text
  rawOcrJson         Json                         @default("{}") @map("raw_ocr_json")
  rawHeuristicJson   Json                         @default("{}") @map("raw_heuristic_json")
  rawGeminiJson      Json                         @default("{}") @map("raw_gemini_json")
  latestErrorCode    String?                      @map("latest_error_code")
  latestErrorMessage String?                      @map("latest_error_message") @db.Text
  attemptCount       Int                          @default(0) @map("attempt_count")
  processedAt        DateTime?                    @map("processed_at")
  confirmedAt        DateTime?                    @map("confirmed_at")
  createdByType      ActorType                    @map("created_by_type")
  createdById        String?                      @map("created_by_id")
