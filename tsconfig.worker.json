{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/server/worker-entrypoint.ts",
    "src/server/pipelines/**/*.ts",
    "src/server/integrations/**/*.ts",
    "src/server/lib/**/*.ts",
    "src/generated/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "test"]
}
