{
  "name": "quoin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3101",
    "build": "node scripts/prepare-build.mjs && next build && npm run worker:build",
    "start": "node scripts/start-server.mjs",
    "stop": "node scripts/stop-local-runtime.mjs",
    "lint": "next lint",
    "typecheck": "node scripts/clean-next-types.mjs && tsc --project tsconfig.typecheck.json --noEmit --incremental false",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "db:start": "npm run services:start:docker",
    "db:stop": "npm run services:stop:docker",
    "db:backfill:green-button-tokens": "tsx scripts/backfill-green-button-token-encryption.ts",
    "db:cutover:reset": "tsx scripts/reset-supabase-cutover.ts",
    "db:audit:tenant": "node scripts/audit-tenant-integrity.mjs",
    "db:validate:constraints": "prisma db execute --file prisma/validate-tenant-constraints.sql",
    "db:validate:fresh": "node scripts/validate-fresh-db.mjs",
    "db:validate:current": "prisma migrate deploy && npm run db:audit:tenant && npm run db:validate:constraints",
    "services:start:docker": "docker compose up -d postgres redis",
    "services:stop:docker": "docker compose stop postgres redis",
    "redis:start:docker": "docker compose up -d redis",
    "redis:stop:docker": "docker compose stop redis",
    "test:integration": "vitest run test/integration",
    "test:integration:db": "node scripts/run-integration-db.mjs",
    "test:unit": "vitest run test/unit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx test/eval/runner.ts",
    "eval:verbose": "tsx test/eval/runner.ts --verbose",
    "rules:regress": "tsx scripts/run-governed-regressions.ts",
    "worker": "tsx src/server/worker-entrypoint.ts",
    "worker:build": "tsc --project tsconfig.worker.json",
    "worker:prod": "node dist/server/worker-entrypoint.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.11.0",
    "@trpc/next": "^11.11.0",
    "@trpc/react-query": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "bullmq": "^5.70.1",
    "fast-xml-parser": "^5.5.9",
    "glob": "^13.0.6",
    "ioredis": "^5.10.0",
    "mapbox-gl": "^3.19.0",
    "next": "14.2.35",
    "p-throttle": "^8.1.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "radix-ui": "^1.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.7.0",
    "shadcn": "^4.0.8",
    "superjson": "^2.2.6",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.577.0",
    "msw": "^2.12.10",
    "postcss": "^8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@types/mapbox__point-geometry": "@mapbox/point-geometry"
  }
}
